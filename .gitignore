# API keys and secrets — never commit real values
.env
.env.local
.env.*.local
# Note: .env.example IS tracked (it's a template with no real values)

# OS files
.DS_Store
Thumbs.db

# Node
node_modules/

# Python
__pycache__/
*.pyc
venv/

# Sensitive client data
projects/*/prospects_enriched.csv
projects/*/client-data/

# IDE
.vscode/
.idea/

# Pipeline output files (may contain enriched prospect data — never commit)
output/*.json
output/*.csv
output/*.md
# Keep the directory itself in the repo
!output/.gitkeep

# Python virtualenv alternatives
.venv/
env/

# Google credentials (never commit)
*-credentials.json
credentials.json

# Variant tracker local SQLite DB
projects/*/data/variants.db
projects/*/data/*.sqlite
projects/*/data/*.sqlite3

# Generated outreach variants (may contain enriched prospect context)
projects/*/outputs/*/