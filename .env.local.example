# For CI/staging/prod, inject these via secret manager or runtime env vars.
# Local API harness template (copy to .env.local)

# CRM provider mode: hubspot | generic
CRM_PROVIDER=hubspot

# HubSpot mode (required when CRM_PROVIDER=hubspot)
HUBSPOT_ACCESS_TOKEN=

# Generic CRM mode (required when CRM_PROVIDER=generic)
CRM_BASE_URL=
CRM_API_KEY=
CRM_COMPANIES_READ_PATH=/companies
CRM_COMPANIES_UPSERT_PATH=/companies/upsert

# Safety (keep 0 unless intentionally testing writes)
LOCAL_API_ALLOW_WRITE=0

# one second API test (current harness target)
# If this points at Deepline, you can reuse DEEPLINE_API_KEY below.
ONE_SECOND_API_URL=http://localhost:8080/health
ONE_SECOND_API_KEY=

# Next integrations you asked for
BIRDDOG_API_KEY=
DEEPLINE_BASE_URL=
DEEPLINE_API_KEY=
SUPERSEND_API_KEY=
# Optional override for event polling endpoint
SUPERSEND_EVENTS_URL=
