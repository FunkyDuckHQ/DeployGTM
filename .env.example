# DeployGTM — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Apollo (contact enrichment) ─────────────────────────────────────────────
APOLLO_API_KEY=

# ─── HubSpot (CRM) ───────────────────────────────────────────────────────────
# Create a private app at: Settings > Integrations > Private Apps
# Scopes needed: crm.objects.contacts.write, crm.objects.companies.write,
#                crm.objects.contacts.read, crm.schemas.contacts.write
HUBSPOT_ACCESS_TOKEN=

# ─── BirdDog (signal monitoring) ─────────────────────────────────────────────
# Obtain from BirdDog dashboard
BIRDDOG_API_KEY=

# ─── SuperSend (email engagement events) ─────────────────────────────────────
# Used by scripts/email_sync.py
SUPERSEND_API_KEY=
# Optional override (default: https://api.supersend.io/v2/events)
SUPERSEND_EVENTS_URL=

# ─── Octave (messaging intelligence) ─────────────────────────────────────────
# Only needed if tools.octave.enabled = true in config.yaml
# Leave blank to use brain/ folder as the Octave replacement
OCTAVE_API_KEY=

# ─── Google Drive (transcript intake) ────────────────────────────────────────
# Path to OAuth credentials JSON downloaded from Google Cloud Console
# Required for the google-drive MCP server
GDRIVE_CREDENTIALS_FILE=~/.config/gdrive-credentials.json
# Folder ID of your DeployGTM Transcript Inbox in Drive
GDRIVE_INTAKE_FOLDER_ID=
