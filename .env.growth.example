# DeployGTM Growth Engine optional integrations
# Copy values into .env only when the relevant adapter is active.

# Research and data access
FIRECRAWL_API_KEY=
CLAY_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_SEARCH_API_KEY=
LINKEDIN_DATA_PROVIDER_KEY=

# Paid acquisition
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=

# Outbound
APOLLO_API_KEY=
INSTANTLY_API_KEY=
HEYREACH_API_KEY=
DRAFTBOARD_API_KEY=

# CRM and automation
HUBSPOT_ACCESS_TOKEN=
N8N_BASE_URL=
N8N_API_KEY=
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL_ID=

# Signal and messaging adapters
BIRDDOG_API_KEY=
OCTAVE_API_KEY=

# Safety defaults
DEPLOYGTM_DEFAULT_MODE=dry_run
DEPLOYGTM_REQUIRE_APPROVAL_FOR_WRITES=true
DEPLOYGTM_ALLOW_PRODUCTION_SENDS=false
